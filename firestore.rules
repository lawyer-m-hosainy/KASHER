rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isUserShop(shopId) {
      return isAuthenticated() && (getUserData().shopId == shopId || getUserData().shopId == 'ADMIN');
    }

    match /shops/{shopId} {
      allow read: if isUserShop(shopId);
      allow create: if request.auth != null && shopId == request.auth.uid && request.resource.data.shopId == shopId;
      allow update: if isUserShop(shopId);
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated() && (userId == request.auth.uid || isUserShop(resource.data.shopId));
      // Net effect: isAdmin can NEVER be set or changed by any client write, ever. shopId/role can never change after creation via client.
      allow create: if request.auth != null && (userId == request.auth.uid || (getUserData().role == 'owner' && request.resource.data.shopId == getUserData().shopId && request.resource.data.role == 'cashier')) && request.resource.data.isAdmin != true;
      allow update: if request.auth != null && userId == request.auth.uid && request.resource.data.shopId == resource.data.shopId && request.resource.data.role == resource.data.role && request.resource.data.isAdmin == resource.data.isAdmin;
    }

    match /products/{productId} {
      allow read: if isUserShop(resource.data.shopId);
      allow create: if isUserShop(request.resource.data.shopId) && 
                       request.resource.data.price >= 0 && 
                       request.resource.data.quantity >= 0 &&
                       request.resource.data.keys().hasAll(['name', 'price', 'quantity', 'shopId']);
      allow update: if isUserShop(resource.data.shopId) && 
                       isUserShop(request.resource.data.shopId) && 
                       request.resource.data.price >= 0 && 
                       request.resource.data.quantity >= 0;
      allow delete: if isUserShop(resource.data.shopId);
    }

    match /sales/{saleId} {
      allow read: if isUserShop(resource.data.shopId);
      allow create: if isUserShop(request.resource.data.shopId) &&
                       request.resource.data.keys().hasAll(['shopId', 'cashierId', 'items', 'total', 'createdAt']);
      allow update, delete: if isUserShop(resource.data.shopId);
    }

    match /customers/{customerId} {
      allow read: if isUserShop(resource.data.shopId);
      allow create: if isUserShop(request.resource.data.shopId) &&
                       request.resource.data.keys().hasAll(['shopId', 'name', 'totalPurchases']);
      allow update: if isUserShop(resource.data.shopId) && isUserShop(request.resource.data.shopId);
      allow delete: if isUserShop(resource.data.shopId);
    }
    
    match /expenses/{expenseId} {
      allow read: if isUserShop(resource.data.shopId);
      allow create: if isUserShop(request.resource.data.shopId) &&
                       request.resource.data.amount >= 0 &&
                       request.resource.data.keys().hasAll(['shopId', 'amount', 'category', 'description', 'date', 'cashierId']);
      allow update: if isUserShop(resource.data.shopId) && isUserShop(request.resource.data.shopId) && request.resource.data.amount >= 0;
      allow delete: if isUserShop(resource.data.shopId);
    }
  }
}
